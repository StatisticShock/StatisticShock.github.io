<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>StatisticShock Index Server</title>
	<link rel="stylesheet" href="style.css">
	<link rel="shortcut icon" href="./favicon.svg" type="image/svg+xml">
</head>

<body>
	<header>StatisticShock.GitHub.io Server</header>
	<div id="container">
		<aside>
			<div class="hb-container">
				<svg id="hb" class="hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 10 10" stroke="#eee" stroke-width=".6" fill="rgba(0,0,0,0)" stroke-linecap="round" style="cursor: pointer">
					<path d="M2,3L5,3L8,3M2,5L8,5M2,7L5,7L8,7">
						<animate dur="0.2s" attributeName="d" values="M2,3L5,3L8,3M2,5L8,5M2,7L5,7L8,7;M3,3L5,5L7,3M5,5L5,5M3,7L5,5L7,7" fill="freeze" begin="start.begin" />
						<animate dur="0.2s" attributeName="d" values="M3,3L5,5L7,3M5,5L5,5M3,7L5,5L7,7;M2,3L5,3L8,3M2,5L8,5M2,7L5,7L8,7" fill="freeze" begin="reverse.begin" />
					</path>
					<rect width="10" height="10" stroke="none">
						<animate dur="2s" id="reverse" attributeName="width" begin="click" />
					</rect>
					<rect width="10" height="10" stroke="none">
						<animate dur="0.001s" id="start" attributeName="width" values="10;0" fill="freeze" begin="click" />
						<animate dur="0.001s" attributeName="width" values="0;10" fill="freeze" begin="reverse.begin" />
					</rect>
				</svg>
			</div>
			<div class="language-wrapper" style="display: none;">
				<p id="language">Language</p>
				<div>
					<input type="radio" id="languageChoice1" name="language" value="en-US" checked="true"/>
					<label for="languageChoice1">English (US)</label>
					<input type="radio" id="languageChoice2" name="language" value="pt-BR" />
					<label for="languageChoice2">Portuguûˆs (Brasil)</label>
				</div>
			</div>
			<nav>
				<a href="#endpoints" style="color: var(--clr-primary-a0); text-decoration: none; margin: 3em 0;">ENDPOINTS</a>
				<div>
					<ûÏ typeOfEndpoints.forEach(function (type) { ûÏ>
						<ûÏ if (type.endpoints.length === 0) {} else { ûÏ>
							<a href="<ûÏ= "#" + type.method.toLowerCase() ûÏ>" style="color: var(--clr-primary-a0); text-decoration: none;"><ûÏ= type.method ûÏ></a>
							<ul>
								<ûÏ type.endpoints.forEach(function (endpoint) { ûÏ>
									<ûÏ const [shortcut] = endpoint.route.match(/[^\?\<\>]*/g) ûÏ>
									<li><a href="<ûÏ= "#" + type.method.toLowerCase() + "-" + endpoint.id ûÏ>"><ûÏ= shortcut ûÏ></a></li>
								<ûÏ }); ûÏ>
							</ul>
						<ûÏ }; ûÏ>
					<ûÏ }); ûÏ>
				</div>
			</nav>
			<style>
				nav {
					--child-count: <ûÏ- (typeOfEndpoints.map((endpoint) => endpoint.endpoints.length + 1)).reduce((prev, curr) => {return prev + curr}, 0) ûÏ>;
				}
			</style>
		</aside>
		<div class="data-wrapper">
			<h1 id="endpoints" style="margin: 0 auto; text-align: center;">ENDPOINTS</h1>
			<p switch="Esta base de dados estûÀ em um arquivo &lt;span class=&quot;codeblock&quot;&gt;Google Sheets&lt;/span&gt;">This database is in a <span class="codeblock">Google Sheets</span> file.</p>
			<ûÏ typeOfEndpoints.forEach(function (type) { ûÏ>
				<ûÏ if (type.endpoints.length === 0) {} else { ûÏ>
					<h2 id="<ûÏ= type.method.toLowerCase() ûÏ>"><ûÏ= type.method ûÏ></h2>
					<p><ûÏ- type.description.en.split("\n").map((line) => "<p>" + line + "</p>").join("") ûÏ></p>
					<ul>
						<ûÏ type.endpoints.forEach(function (endpoint) { ûÏ>
							<div class="endpoint-wrapper" id="<ûÏ= type.method.toLowerCase() + "-" + endpoint.id ûÏ>">
								<h3 class="route"><ûÏ= endpoint.route ûÏ></h1>
								<div class="description"><ûÏ- endpoint.description.en.split("\n").map((text) => `<p>${text}</p>`).join("") ûÏ></div>
								<ûÏ if (endpoint.parameters) { ûÏ>
									<div class="parameter">
										<ûÏ endpoint.parameters.forEach((parameter) => { ûÏ>
											<div class="parameter-name"><ûÏ- parameter[0] ûÏ></div>
											<div class="parameter-description" switch="<ûÏ- parameter[1].pt.replace(/\n/g, "<br><br>").replace(/\"/g, "'") ûÏ>"><ûÏ- parameter[1].en.split(/\n/g).map((line) => "<p>" + line + "</p>").join("") ûÏ></div>
										<ûÏ }); ûÏ>
									</div>
								<ûÏ } ûÏ>
								<ûÏ if (endpoint.examples) { ûÏ>
									<div class="examples">
										<ûÏ endpoint.examples.forEach((example) => { ûÏ>
											<div class="example"><p><span pos="right">&gt;</span>&nbsp;<ûÏ- example[0] ûÏ></p></div>
											<div class="example-output"><ûÏ- example[1].split("\n").map((line) => "<p>" + line.replace(/\t/g, "&nbsp;&nbsp;&nbsp;&nbsp;") + "</p>").join("") ûÏ></div>
										<ûÏ }); ûÏ>
									</div>
								<ûÏ }; ûÏ>
							</div>
						<ûÏ }) ûÏ>
					</ul>
				<ûÏ }; ûÏ>
			<ûÏ }); ûÏ>
		</div>
	</div>
	<footer></footer>
	<script>
		function getCheckedValue(groupName) {
			const radios = document.getElementsByName(groupName);

			for(const radio of radios) {
				if(radio.checked) {
					return radio.value;
				};
			};

			return null;
		};

		(function changeLanguage () {
			const div = document.querySelector(".language-wrapper div");
			div.addEventListener("click", detectLanguageChange);

			function detectLanguageChange () {
				const language = getCheckedValue("language")

				// switch (language) {
				// 	case "pt-BR":
				// 		document.querySelector("p#language").innerHTML = "Idioma";
				// 	case "en-US":
				// 		document.querySelector("p#language").innerHTML = "Language";
				// 	default:
				// 		document.querySelector("p#language").innerHTML = "Language";
				// }
			};
		})();

		(function toggleExamples () {
			const exampleHeaders = document.querySelectorAll("div.example");

			exampleHeaders.forEach((example) => {
				example.addEventListener("click", (ev) => {
					if (example.querySelector(":scope > p > span").getAttribute("pos") === "right") {
						example.querySelector(":scope > p > span").setAttribute("pos", "down");
					} else {
						example.querySelector(":scope > p > span").setAttribute("pos", "right");
					};
				});
			});
		})();

		(async function putVersionOnFooter () {
			const version = await fetch(`/version`).then((res) => res.json());
			const footer = document.querySelector("footer");

			footer.innerHTML += `<p><small>ver. ${version.server}</small></p>`;
		})();

		(function collapseAside () {
			const aside = document.querySelector("aside");
			const hb = aside.querySelector("#hb");

			window.addEventListener("click" , (ev) => {
				console.log(ev);

				const target = ev.touches ? ev.touches[0].target : ev.target;
				
				if (hb.contains(target) || target === hb) {
					hb.classList.toggle("hidden");
				} else if (!(aside.contains(target)) && !(hb.classList.contains("hidden")) || target.tagName === "A") {
					hb.querySelector("#reverse").beginElement();
					hb.classList.toggle("hidden");
				};
			});
		})();

		(function setAsideMinWidth () {
			const aside = document.querySelector("aside");
			const container = document.querySelector("div#container");
			const lis = container.querySelectorAll("ul li");
			const minWidth = Array.from(lis).reduce((prev, curr) => {return Math.max(prev, curr.textContent.length)}, "");

			console.log(minWidth);

			aside.style.setProperty("--min-width", (minWidth / 1.25) + "em");
		})();

		(function setExampleHeight () {
			const examples = document.querySelectorAll(".example-output");

			examples.forEach((example) => {
				const lines = Array.from(example.querySelectorAll("p")).length;

				example.style.setProperty("--example-height", "calc(" + (lines * 1.125) + "em + 3px)")
			})
		})();

		(function toggleLanguage () {
			const languageInputs = document.querySelectorAll("input[name=\"language\"]");
			
			languageInputs.forEach((input) => {
				input.addEventListener("click", (ev) => {

				});
			});
		})();
	</script>
</body>

</html>